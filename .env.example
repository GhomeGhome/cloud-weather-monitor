PROJECT_ID=your-gcp-project-id
REGION=europe-west6
DATASET_ID=weather_analytics
INDOOR_TABLE=indoor_metrics
OUTDOOR_TABLE=outdoor_weather
EVENTS_TABLE=device_events
LATEST_TABLE=latest_state

# API auth
INGESTION_SHARED_SECRET=replace-me

# OpenWeather
OPENWEATHER_API_KEY=replace-me
OPENWEATHER_LAT=46.5197
OPENWEATHER_LON=6.6323
OPENWEATHER_UNITS=metric
OPENWEATHER_LANG=en

# Optional speech services
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_TTS_ENABLED=false
GOOGLE_STT_ENABLED=false
